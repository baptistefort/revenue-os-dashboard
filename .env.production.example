# Copy to .env.production on the VPS and set chmod 600.
# Never commit the real file.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin

FISH_AUDIO_API_KEY=
FISH_AUDIO_REFERENCE_ID=e11e47c85dc7449a9ce30c0993f87f91
FISH_AUDIO_MODEL=s2.1-pro
FISH_AUDIO_LATENCY=low

# The app reaches OpenCode through the private Docker network.
OPENCODE_BASE_URL=http://opencode:4096
OPENCODE_HOSTNAME=0.0.0.0
OPENCODE_PORT=4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=replace_with_a_long_random_secret
OPENCODE_SESSION_SECRET=replace_with_an_independent_64_byte_secret
OPENCODE_DIRECTORY=/workspace/ops
OPENCODE_AGENT=ops
OPENCODE_PROVIDER=openai
OPENCODE_MODEL=gpt-5.4-mini
OPENCODE_TIMEOUT_MS=60000
OPENCODE_STRUCTURED_OUTPUT_RETRIES=0

OBSIDIAN_VAULT_PATH=/data/obsidian
OBSIDIAN_MEMORY_CACHE_TTL_MS=5000
OPS_DOCUMENTS_PATH=/data/documents
OPS_BUSINESS_DATE=2026-07-17
OPS_ORGANIZATION_SLUG=atelier-beaumarchais
OPS_UNIVERSE_AS_OF=2026-07-17T08:00:00.000Z

# Server-to-server only. Generate with `openssl rand -hex 32`. Use
# OPS_INGESTION_TOKENS_JSON instead when one deployment hosts several tenants.
OPS_INGESTION_TOKEN=replace_with_an_independent_connector_secret
# OPS_INGESTION_TOKENS_JSON={"atelier-beaumarchais":"replace_me"}

# Private PostgreSQL service. Generate a long password and URL-encode it in
# DATABASE_URL. These values remain server-side in the mode-600 env file.
POSTGRES_DB=ops
POSTGRES_USER=ops
POSTGRES_PASSWORD=replace_with_an_independent_long_random_secret
DATABASE_URL=postgresql://ops:replace_with_url_encoded_secret@database:5432/ops
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=4000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_APPLICATION_NAME=ops-web
