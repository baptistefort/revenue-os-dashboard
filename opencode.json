{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "snapshot": false,
  "autoupdate": false,
  "enabled_providers": [
    "openai"
  ],
  "model": "openai/gpt-5.4-mini",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "ops",
  "tools": {
    "*": false,
    "ops_*": true
  },
  "permission": {
    "*": "deny",
    "ops_*": "allow"
  },
  "watcher": {
    "ignore": [
      ".next/**",
      "node_modules/**",
      "public/generated/**",
      "*.log"
    ]
  },
  "tool_output": {
    "max_lines": 400,
    "max_bytes": 50000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 12
  }
}
