# Create .env.local and paste a NEW key that has never been exposed publicly.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin

# Primary OPS output voice. Keep the API key server-side only.
FISH_AUDIO_API_KEY=
FISH_AUDIO_REFERENCE_ID=e11e47c85dc7449a9ce30c0993f87f91
FISH_AUDIO_MODEL=s2.1-pro
FISH_AUDIO_LATENCY=low

# Private OpenCode server. Keep this URL server-side only.
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_HOSTNAME=127.0.0.1
OPENCODE_PORT=4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
OPENCODE_SESSION_SECRET=
OPENCODE_DIRECTORY=/absolute/path/to/this/dashboard
OPENCODE_AGENT=ops
OPENCODE_PROVIDER=openai
OPENCODE_MODEL=gpt-5.4-mini
OPENCODE_TIMEOUT_MS=45000
OPENCODE_STRUCTURED_OUTPUT_RETRIES=0

# Freeze the business clock for a reproducible workspace snapshot.
OPS_BUSINESS_DATE=2026-07-17
OPS_ORGANIZATION_SLUG=atelier-beaumarchais
OPS_UNIVERSE_AS_OF=2026-07-17T08:00:00.000Z

# Local-only path to the Obsidian vault used by the Cerveau route.
OBSIDIAN_VAULT_PATH=/absolute/path/to/your/Obsidian/Vault
OPS_DOCUMENTS_PATH=/absolute/path/to/persistent/generated-documents

# Authoritative OPS memory. Obsidian remains a downstream projection.
# Use a dedicated local PostgreSQL user and percent-encode special characters
# in DATABASE_URL. Never expose this URL to the browser.
POSTGRES_DB=ops
POSTGRES_USER=ops
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://ops:replace_me@127.0.0.1:5432/ops
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=4000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_APPLICATION_NAME=ops-web-local

# Protected server-to-server connector ingestion. Generate a long random token;
# it never belongs in NEXT_PUBLIC_* or in browser code. For multi-tenant
# deployments, prefer OPS_INGESTION_TOKENS_JSON={"tenant-slug":"secret"}.
OPS_INGESTION_TOKEN=
# OPS_INGESTION_TOKENS_JSON=
